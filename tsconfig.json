{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["DOM", "DOM.Iterable", "ES2023", "ScriptHost"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "noEmitOnError": true,
    "outDir": "./dist",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "es2023",
    "useDefineForClassFields": false,
    "baseUrl": ".",
    "paths": {
      "openclaw/channels/plugins/types.adapters": ["./node_modules/openclaw/dist/plugin-sdk/src/channels/plugins/types.adapters.d.ts"],
      "openclaw/infra/outbound/deliver": ["./node_modules/openclaw/dist/plugin-sdk/src/infra/outbound/deliver.d.ts"]
    }
  },
  "include": ["src/**/*", "index.ts"],
  "exclude": ["node_modules", "dist", "tests"]
}